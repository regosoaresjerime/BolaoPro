# Copie este arquivo para `.env.local` em desenvolvimento.
# Na Vercel, configure somente as variaveis `VITE_*` no painel do projeto.
# Secrets sensiveis de Edge Functions devem ser configurados no Supabase, nao na Vercel.

# Frontend (Vercel / Vite)
VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_ANON_KEY="SUA_CHAVE_ANON_PUBLICA"

# Opcional: URL publica da aplicacao para callbacks e documentacao operacional
APP_URL="https://seu-projeto.vercel.app"

# Supabase Edge Functions
SUPABASE_SERVICE_ROLE_KEY="SUA_SERVICE_ROLE_KEY"
PAGBANK_TOKEN="SEU_TOKEN_PAGBANK"
PAGBANK_SANDBOX="true"
PAGBANK_PROD_ENABLED="false"
N8N_WEBHOOK_URL=""
